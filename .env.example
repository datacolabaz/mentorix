# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/school_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# File Upload (AWS S3 or local)
UPLOAD_PROVIDER=local
LOCAL_UPLOAD_PATH=./uploads
AWS_BUCKET_NAME=school-system-files
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# WhatsApp / SMS (Twilio or local provider)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=

# GoldenPay (Azerbaijan)
GOLDENPAY_TOKEN=
GOLDENPAY_CALLBACK_URL=https://yourdomain.com/api/payments/goldenpay/callback

# MilliÖN
MILLION_MERCHANT_ID=
MILLION_SECRET_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:3000
